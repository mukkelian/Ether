# Wannier program's Makefile has been used in building this Makefile
# Ref:: (http://www.wannier.org/download/)

#--- gnu
 f90comp = mpif90
 switch = -O3 -fopenmp -march=native -funroll-loops -finline-functions \
       -fno-math-errno -fno-trapping-math

#--- for gnu debug
# switch = -O0 -fopenmp -g -fcheck=all

#--- intel
#f90comp = mpiifx
#switch = -O3 -qopenmp

#--- for intel debug
# switch = -O0 -qopenmp -check all -traceback -g -warn unused -debug
